$changedFiles = 0;
$changedLines = 0;
$targetDir = realpath($targetDir);
$iterator = new RecursiveIteratorIterator(
    new RecursiveDirectoryIterator($targetDir, FilesystemIterator::SKIP_DOTS)
);

foreach ($iterator as $file) {
    if ($file->getExtension() !== 'less') {
        continue;
    }

    $path = $file->getPathname();
    $relativePath = substr($path, strlen($targetDir) + 1);
    $content = file_get_contents($path);
    $original = $content;

    if (!$content) {
        if ($content === false) {
            echo "[ERROR] Cannot read: $relativePath\n";
        }
        continue;
    }

    $matches = [
        'inform' => [],
        'fixes' => [],
    ];
    foreach ($rules as $values) {
        foreach ($values['exclude'] as $exclude) {
            if (strstr($relativePath, $exclude)) {
                continue 2;
            }
        }
        foreach ($values['mapping'] as $search => $replace) {
            if ($values['mode'] === 'inform') {
                if (strstr($content, $search)) {
                    $matches['inform'][] = [$search => $replace];
                }
            } elseif ($values['mode'] === 're') {
                $content = preg_replace_callback(
                    $search,
                    function ($match) use (&$matches, $replace) {
                        $result = preg_replace_callback('/\$(\d+)/', function ($m) use ($match) {
                            return $match[(int) $m[1]] ?? '';
                        }, $replace);

                        $matches['fixes'][] = [$match[0] => $result];

                        return $result;
                    },
                    $content
                );
            } elseif ($search[0] === '*') {
                $suffix = preg_quote(substr($search, 1), '#');
                $pattern = '#(@[a-zA-Z0-9\-_]+)' . $suffix . '#';

                $content = preg_replace_callback(
                    $pattern,
                    function ($match) use (&$matches, $replace) {
                        $replace = str_replace('*', $match[1], $replace);
                        $matches['fixes'][] = [$match[0] => $replace];
                        return $replace;
                    },
                    $content
                );
            } elseif (strstr($content, $search)) {
                $matches['fixes'][] = [$search => $replace];
                $content = str_replace($search, $replace, $content);
            }
        }
    }

    if (count($matches['fixes']) || count($matches['inform'])) {
        $informCount = count($matches['inform']);
        $matchesCount = count($matches['fixes']);
        $changedLines += $matchesCount;
        $changedFiles++;

        $backupPath = $path . '.breeze-2-to-3.bak';

        if (file_exists($backupPath)) {
            echo "\033[33m[SKIPPED] $relativePath (Backup exists, so the file was likely processed)\033[0m";
        } else {
            if ($applyFix) {
                if ($content !== $original) {
                    if (!copy($path, $backupPath)) {
                        throw new \RuntimeException("Failed to create backup for $path");
                    }
                    file_put_contents($path, $content);
                }
                echo "\033[32m[FIXED] $relativePath Fixable: $matchesCount; Manual: $informCount\033[0m";
            } else {
                echo "\033[32m[FOUND] $relativePath Fixable: $matchesCount; Manual: $informCount\033[0m";
            }
        }

        if (count($matches['inform'])) {
            echo "\n\t\033[33m" . implode("\n\t", array_map(
                fn($item) => key($item) . ' => ' . current($item),
                $matches['inform']
            )) . "\033[0m";
        }
        if (count($matches['fixes'])) {
            echo "\n\t" . implode("\n\t", array_map(
                fn($item) => key($item) . ' => ' . current($item),
                $matches['fixes']
            ));
        }
        echo "\n\n";
    }
}

echo "Done. Files: $changedFiles, Lines: $changedLines\n";
echo $applyFix ? "Mode: FIX\n" : "Mode: DRY RUN (use --fix to apply)\n";
